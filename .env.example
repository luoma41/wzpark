# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/wzpark?retryWrites=true&w=majority

# Tencent Cloud COS credentials
COS_SECRET_ID=your-tencent-cloud-secret-id
COS_SECRET_KEY=your-tencent-cloud-secret-key
COS_BUCKET=wzpark-photos
COS_REGION=ap-guangzhou
COS_APPID=your-tencent-cloud-appid

# JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
JWT_SECRET=your-super-secret-jwt-key-here-min-32-chars

# Admin credentials
ADMIN_EMAIL=your-email@example.com
ADMIN_PASSWORD_HASH=$2a$10$... # Generate with bcrypt
